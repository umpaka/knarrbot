# Telegram Bot Token — get one from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-token-here

# Google Gemini API key — enables natural language LLM routing
# Get one at https://aistudio.google.com/apikey
# Optional: without this, the bot runs in command-only mode (/help, /run, etc.)
GEMINI_API_KEY=your-key-here

# Knarr Cockpit API — the bot talks to an external Knarr node via HTTP REST.
# Point to your node's cockpit server.
KNARR_API_URL=http://localhost:9100
KNARR_API_TOKEN=

# Optional: LiteLLM fallback when Gemini is down or rate-limited
# FALLBACK_MODEL=openrouter/anthropic/claude-sonnet-4
# FALLBACK_API_KEY=your-key-here

# Optional: access control (empty = open access)
# ALLOWED_USERS=123456789,987654321
# ALLOWED_GROUPS=-100123456789

# Optional: proactive heartbeat
# HEARTBEAT_CHAT_ID=123456789
# HEARTBEAT_INTERVAL=1800

# Optional: knarr-mail polling interval (seconds)
# MAIL_POLL_INTERVAL=10

# Optional: postmaster email integration
# POSTMASTER_DB=/path/to/postmaster.db
# EMAIL_POLL_INTERVAL=15
