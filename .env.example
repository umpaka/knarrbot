# Telegram Bot Token — get one from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-token-here

# Knarr Cockpit API — the bot talks to an external Knarr node via HTTP REST.
# Point to your node's cockpit server.
KNARR_API_URL=http://localhost:9100
KNARR_API_TOKEN=

# ── LLM Configuration ──────────────────────────────────
# Option 1: Provider-agnostic via LiteLLM (recommended)
# Supports Gemini, Claude, OpenAI, local models, custom proxies — anything LiteLLM supports.
# LLM_MODEL=gemini/gemini-2.0-flash
# LLM_API_KEY=your-key-here
# LLM_API_BASE=                  # optional: custom endpoint URL

# Option 2: Direct Gemini (legacy, still works)
# GEMINI_API_KEY=your-key-here

# Optional: LiteLLM fallback when using direct Gemini (Option 2)
# FALLBACK_MODEL=openrouter/anthropic/claude-sonnet-4
# FALLBACK_API_KEY=your-key-here

# ── Access Control ──────────────────────────────────────
# Optional: restrict who can talk to the bot (empty = open access)
# ALLOWED_USERS=123456789,987654321
# ALLOWED_GROUPS=-100123456789

# ── Proactive Features ─────────────────────────────────
# HEARTBEAT_CHAT_ID is auto-set when the owner first claims the bot (DM).
# Set manually if you want to pin heartbeat output to a specific chat.
# HEARTBEAT_CHAT_ID=123456789
# HEARTBEAT_INTERVAL=1800
# MAIL_POLL_INTERVAL=10
# POSTMASTER_DB=/path/to/postmaster.db
# EMAIL_POLL_INTERVAL=15

# ── Vault (long-term memory) ────────────────────────────
# Install: git clone https://github.com/umpaka/vault /opt/knarr-skills/vault
# Then seed: cp -r vault-templates/. /opt/knarr-vault/default/
# Vault data root — must match VAULT_ROOT in vault/.env
VAULT_ROOT=/opt/knarr-vault

# ── Cost optimisation ───────────────────────────────────
# Use a cheaper/faster model for background heartbeat cycles.
# Heartbeats run every 30 minutes — a small model saves significant cost.
# FAST_LLM_MODEL=openai/gemini-2.0-flash
